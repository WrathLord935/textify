{
  "name": "latex-gen",
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run build --workspace=latex-gen-client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
